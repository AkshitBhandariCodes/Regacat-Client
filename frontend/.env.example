# Common environment file for both frontend (Vite) and backend (Node server)

# Shared app config
APP_HOME_URL=https://regacats.in
MAIL_API_PORT=8787

# Frontend (Vite) values must start with VITE_
VITE_SITE_URL=https://regacats.in
# For split hosting, point frontend API calls to the API subdomain.
VITE_API_BASE_URL=https://api.regacats.in

# Mail server config
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contactform.regacats@gmail.com
SMTP_PASS=replace-with-app-password

MAIL_FROM="Regacats Website <contactform.regacats@gmail.com>"
MAIL_TO_PRIMARY=contactform.regacats@gmail.com
MAIL_TO_SECONDARY=kumaraxshit@gmail.com
MAIL_TO_TERTIARY=anuj@regacats.in

MAIL_ALLOWED_ORIGINS=https://regacats.in
